# Normalize line endings. Without this, editing on Windows (e.g. Geany) rewrites
# LF files as CRLF and `git status` shows every line of a file as changed.
# Repo stores LF; Git converts per-platform on checkout where needed.
* text=auto eol=lf

# Windows batch scripts must stay CRLF to run correctly.
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Shell scripts (incl. the Gradle wrapper) must stay LF.
*.sh     text eol=lf
gradlew  text eol=lf

# Binary assets — Git must never touch these.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.jar  binary
*.war  binary
*.zip  binary
*.wav  binary
*.mp3  binary
*.ogg  binary
*.ttf  binary
*.otf  binary
*.apk  binary
